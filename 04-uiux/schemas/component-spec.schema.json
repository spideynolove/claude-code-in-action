{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ComponentSpec",
  "type": "object",
  "required": ["components"],
  "properties": {
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "properties": {
          "name": { "type": "string" },
          "source": {
            "type": "string",
            "enum": ["catalog", "extend", "new"]
          },
          "variants": { "type": "object" },
          "states": {
            "type": "array",
            "items": { "type": "string" }
          },
          "props": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
