{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IntentSpec",
  "type": "object",
  "required": [
    "product_type",
    "primary_user",
    "main_jobs",
    "risk_level",
    "interaction_density",
    "tone",
    "constraints"
  ],
  "properties": {
    "product_type": { "type": "string" },
    "primary_user": { "type": "string" },
    "main_jobs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "interaction_density": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "tone": { "type": "string" },
    "constraints": {
      "type": "object",
      "properties": {
        "must_support_dark_mode": { "type": "boolean" },
        "must_be_keyboard_accessible": { "type": "boolean" },
        "avoid_styles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "preferred_styles": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
