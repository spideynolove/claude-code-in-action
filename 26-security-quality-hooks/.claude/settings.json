{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/secret-scanner.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/dangerous-command-blocker.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/conventional-commits.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tdd-gate.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/plan-gate.sh"
          }
        ]
      }
    ]
  }
}
